{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "ios",
  "description": "Capability for the iOS app",
  "platforms": ["iOS"],
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://*"
        },
        {
          "url": "http://*"
        }
      ]
    },
    "dialog:default",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-read-text-file",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-stat",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPDATA/**",
        "$DOCUMENT/**"
      ]
    },
    "oauth:allow-start",
    "oauth:allow-cancel",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "notification:default",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "notification:allow-notify"
  ]
}
